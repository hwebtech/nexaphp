# NexaPHP Application Settings
APP_NAME=NexaPHP
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:7272

# Database Settings
# Set to 'mysql' to use MySQL (ensure DB created)
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=nexadb
DB_USER=root
DB_PASSWORD=

# Mail/SMTP Settings
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=support@hweb.tech
MAIL_FROM_NAME="${APP_NAME}"
