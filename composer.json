{
    "name": "hwebtech/nexa",
    "description": "NexaPHP Framework — Build Fast. Scale Limitlessly.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "CODEBYHWEB",
            "role": "Lead Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.5",
        "phpmailer/phpmailer": "^6.8",
        "dompdf/dompdf": "^2.0",
        "league/csv": "^9.9"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/",
            "core\\": "core/"
        }
    },
    "bin": ["nexa"],
    "scripts": {
        "post-create-project-cmd": [
            "php -r \"copy('.env.example', '.env');\"",
            "php nexa key:generate"
        ]
    }
}
